/*
 * ESP32 GIMBAL AUTO-TUNING
 * Automatically find optimal PID gains using Relay Method
 * 
 * HOW IT WORKS:
 * 1. Apply step input to motor
 * 2. Measure oscillation period (Tu) and amplitude
 * 3. Calculate ultimate gain (Ku)
 * 4. Use Ziegler-Nichols rules to find Kp, Ki, Kd
 * 
 * USAGE:
 * 1. Upload this code
 * 2. Open Serial Monitor (115200 baud)
 * 3. Send 'T' to tune Tilt motor
 * 4. Send 'P' to tune Pan motor
 * 5. Wait ~30 seconds for auto-tuning
 * 6. Copy optimal PID values to main code
 */

#include <Arduino.h>
#include "Bluetooth.h" 
#include <SimpleFOC.h>

// --- MOTOR SETUP (SAME AS YOUR CODE) ---
constexpr uint8_t PIN_UH_1 = 0, PIN_VH_1 = 2,  PIN_WH_1 = 15,  PIN_EN_1 = 4;
constexpr uint8_t PIN_UH_2 = 12, PIN_VH_2 = 14, PIN_WH_2 = 27, PIN_EN_2 = 13;
constexpr uint8_t POLE_PAIRS = 11;
constexpr uint8_t POLE_PAIRS_1 = 7;
constexpr float SUPPLY_V = 12.0;

BLDCMotor       motor1 (POLE_PAIRS_1);
BLDCDriver3PWM  driver1(PIN_UH_1, PIN_VH_1, PIN_WH_1, PIN_EN_1);
BLDCMotor       motor2 (POLE_PAIRS);
BLDCDriver3PWM  driver2(PIN_UH_2, PIN_VH_2, PIN_WH_2, PIN_EN_2);
BLDCMotor       motor3 (POLE_PAIRS);
BLDCDriver3PWM  driver3(PIN_UH_3, PIN_VH_3, PIN_WH_3, PIN_EN_3);

// --- AUTO-TUNING STATE ---
enum TuningState {
  IDLE,
  TUNING_TILT,
  TUNING_PAN,
  DONE
};

TuningState tuning_state = IDLE;

// Tuning parameters
float test_amplitude = 10.0f * DEG_TO_RAD;  // ±10° test movement
float base_position_tilt = 90.0f * DEG_TO_RAD;
float base_position_pan = 0.0f;

// Oscillation detection
unsigned long oscillation_start_time = 0;
float last_position = 0;
float peak_positions[10];
int peak_count = 0;
bool going_up = true;

// Results
float Ku = 0;  // Ultimate gain
float Tu = 0;  // Ultimate period
float optimal_Kp = 0;
float optimal_Ki = 0;
float optimal_Kd = 0;

// --- RELAY AUTO-TUNING FUNCTION ---
void performAutoTuning(BLDCMotor* motor, float base_pos, const char* motor_name) {
  Serial.printf("\n========================================\n");
  Serial.printf("AUTO-TUNING %s MOTOR\n", motor_name);
  Serial.printf("========================================\n");
  Serial.println("Starting relay test...");
  
  // Reset variables
  peak_count = 0;
  oscillation_start_time = millis();
  last_position = base_pos;
  going_up = true;
  
  // Phase 1: Apply relay (bang-bang control) to induce oscillation
  float relay_output = 0.5f;  // Start with moderate gain
  float target = base_pos;
  int cycle_count = 0;
  unsigned long phase1_start = millis();
  
  while (cycle_count < 5 && (millis() - phase1_start) < 30000) {  // Max 30 seconds
    motor->loopFOC();
    
    // Relay control: switch between +/- amplitude
    float current_pos = motor->shaft_angle;
    float error = target - current_pos;
    
    if (error > 0.05f) {
      target = base_pos + test_amplitude;
    } else if (error < -0.05f) {
      target = base_pos - test_amplitude;
    }
    
    motor->move(target);
    
    // Detect peaks (oscillation)
    if (going_up && current_pos > last_position) {
      // Still going up
    } else if (going_up && current_pos < last_position) {
      // Peak detected!
      peak_positions[peak_count++] = last_position;
      going_up = false;
      cycle_count++;
      Serial.printf("Peak %d detected at %.2f°\n", peak_count, last_position * RAD_TO_DEG);
    } else if (!going_up && current_pos < last_position) {
      // Still going down
    } else if (!going_up && current_pos > last_position) {
      // Valley detected
      going_up = true;
    }
    
    last_position = current_pos;
    delay(10);  // 100Hz sampling
  }
  
  // Phase 2: Calculate oscillation parameters
  if (peak_count >= 3) {
    // Calculate period (Tu) from peak intervals
    unsigned long total_time = millis() - oscillation_start_time;
    Tu = (total_time / 1000.0f) / (peak_count - 1);  // Average period in seconds
    
    // Calculate amplitude
    float total_amplitude = 0;
    for (int i = 0; i < peak_count; i++) {
      total_amplitude += abs(peak_positions[i] - base_pos);
    }
    float avg_amplitude = total_amplitude / peak_count;
    
    // Calculate ultimate gain (Ku)
    // Ku = (4 * relay_amplitude) / (π * oscillation_amplitude)
    Ku = (4.0f * test_amplitude) / (PI * avg_amplitude);
    
    Serial.printf("\n=== OSCILLATION ANALYSIS ===\n");
    Serial.printf("Period (Tu): %.3f seconds\n", Tu);
    Serial.printf("Amplitude: %.2f degrees\n", avg_amplitude * RAD_TO_DEG);
    Serial.printf("Ultimate Gain (Ku): %.4f\n", Ku);
    
    // Phase 3: Calculate PID using Ziegler-Nichols rules
    // Classic PID:
    //   Kp = 0.6 * Ku
    //   Ki = 2 * Kp / Tu = 1.2 * Ku / Tu
    //   Kd = Kp * Tu / 8 = 0.075 * Ku * Tu
    
    optimal_Kp = 0.6f * Ku;
    optimal_Ki = 1.2f * Ku / Tu;
    optimal_Kd = 0.075f * Ku * Tu;
    
    // For gimbal, reduce Ki to avoid overshoot
    optimal_Ki = optimal_Ki * 0.1f;  // 10% of calculated value
    
    Serial.printf("\n=== OPTIMAL PID (Ziegler-Nichols) ===\n");
    Serial.printf("Kp = %.4f\n", optimal_Kp);
    Serial.printf("Ki = %.4f\n", optimal_Ki);
    Serial.printf("Kd = %.4f\n", optimal_Kd);
    
    Serial.printf("\n=== COPY TO YOUR CODE ===\n");
    Serial.printf("PID_Controller pid%s(\n", motor_name);
    Serial.printf("    %.4ff,  // Kp\n", optimal_Kp);
    Serial.printf("    %.4ff,  // Ki\n", optimal_Ki);
    Serial.printf("    %.4ff,  // Kd\n", optimal_Kd);
    Serial.printf("    %.2ff * DEG_TO_RAD\n", base_pos * RAD_TO_DEG);
    Serial.printf(");\n");
    
  } else {
    Serial.println("ERROR: Not enough oscillations detected!");
    Serial.println("Try:");
    Serial.println("  - Increase test_amplitude");
    Serial.println("  - Check motor connections");
    Serial.println("  - Reduce mechanical friction");
  }
  
  // Return to base position
  for (int i = 0; i < 100; i++) {
    motor->loopFOC();
    motor->move(base_pos);
    delay(10);
  }
  
  Serial.println("\nAuto-tuning complete!");
  Serial.println("========================================\n");
}

// --- SETUP ---
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("\n\n");
  Serial.println("========================================");
  Serial.println("ESP32 GIMBAL AUTO-TUNING");
  Serial.println("========================================");
  Serial.println("Commands:");
  Serial.println("  T - Auto-tune Tilt motor");
  Serial.println("  P - Auto-tune Pan motor");
  Serial.println("  H - Hold current position (test)");
  Serial.println("========================================\n");
  
  // Initialize motors (same as your code)
  driver1.voltage_power_supply = SUPPLY_V;
  driver1.pwm_frequency = 25000;
  driver1.init();
  motor1.linkDriver(&driver1);
  motor1.controller = MotionControlType::angle_openloop;
  motor1.voltage_limit = 7.0f;
  motor1.velocity_limit = 2.0f;
  motor1.current_limit = 1;
  motor1.init();
  
  driver2.voltage_power_supply = SUPPLY_V;
  driver2.pwm_frequency = 20000;
  driver2.init();
  motor2.linkDriver(&driver2);
  motor2.controller = MotionControlType::angle_openloop;
  motor2.voltage_limit = 7.0f;
  motor2.velocity_limit = 2.0f;
  motor2.current_limit = 1;
  motor2.init();
  
  driver3.voltage_power_supply = SUPPLY_V;
  driver3.pwm_frequency = 20000;
  driver3.init();
  motor3.linkDriver(&driver3);
  motor3.controller = MotionControlType::angle_openloop;
  motor3.voltage_limit = 5.0f;
  motor3.velocity_limit = 1.5f;
  motor3.current_limit = 1;
  motor3.init();
  
  Serial.println("Motors initialized. Ready for tuning!");
  Serial.println("Send 'T' or 'P' to start...\n");
}

// --- LOOP ---
void loop() {
  // Always run FOC
  motor1.loopFOC();
  motor2.loopFOC();
  motor3.loopFOC();
  
  // Check for serial commands
  if (Serial.available()) {
    char cmd = Serial.read();
    
    if (cmd == 'T' || cmd == 't') {
      tuning_state = TUNING_TILT;
      performAutoTuning(&motor2, base_position_tilt, "TILT");
      tuning_state = DONE;
      
    } else if (cmd == 'P' || cmd == 'p') {
      tuning_state = TUNING_PAN;
      performAutoTuning(&motor1, base_position_pan, "PAN");
      tuning_state = DONE;
      
    } else if (cmd == 'H' || cmd == 'h') {
      Serial.println("Holding position...");
      for (int i = 0; i < 500; i++) {
        motor1.loopFOC();
        motor2.loopFOC();
        motor3.loopFOC();
        motor1.move(base_position_pan);
        motor2.move(base_position_tilt);
        motor3.move(90.0f * DEG_TO_RAD);
        delay(10);
      }
      Serial.println("Hold complete.");
    }
  }
  
  // Idle mode: hold position
  if (tuning_state == IDLE || tuning_state == DONE) {
    motor1.move(base_position_pan);
    motor2.move(base_position_tilt);
    motor3.move(90.0f * DEG_TO_RAD);
  }
  
  delay(1);
}
